{
	"name": "electrobun-angular",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app with Angular and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"@angular/common": "^19.2.19",
		"@angular/compiler": "^19.2.19",
		"@angular/core": "^19.2.19",
		"@angular/platform-browser": "^19.2.19",
		"@angular/platform-browser-dynamic": "^19.2.19",
		"electrobun": "file:../../package",
		"rxjs": "^7.8.2",
		"zone.js": "^0.15.1"
	},
	"devDependencies": {
		"@analogjs/vite-plugin-angular": "^1.22.5",
		"@angular/build": "^19.2.22",
		"@angular/compiler-cli": "^19.2.19",
		"@types/bun": "latest",
		"concurrently": "^9.2.1",
		"typescript": "~5.8.3",
		"vite": "^6.4.1"
	},
	"trustedDependencies": [
		"@parcel/watcher"
	]
}
